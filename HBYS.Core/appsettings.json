{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=HbysDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "logs/hbys-.txt", "rollingInterval": "Day" } }
    ]
  },
  "AllowedHosts": "*"
}
