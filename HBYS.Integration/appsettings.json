{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "logs/integration-.txt", "rollingInterval": "Day" } }
    ]
  },
  "HL7": { "Port": 2575 },
  "HBYS": { "ApiBaseUrl": "https://localhost:5001/api" }
}
